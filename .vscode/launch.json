{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Backend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-r",
        "ts-node/register",
        "-r",
        "tsconfig-paths/register"
      ],
      "args": ["src/index.ts"],
      "cwd": "${workspaceFolder}/src/backend",
      "envFile": "${workspaceFolder}/src/backend/.env",
      "console": "integratedTerminal"
    }
  ]
}